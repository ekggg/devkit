{
  "$schema": "https://ekg.gg/schemas/manifest.json",
  "type": "overlay",
  "name": "Test Widget",
  "version": "1.0.2",
  "description": "",
  "size": {
    "width": 2000,
    "height": 1000
  },
  "template": "template.hbs",
  "css": "styles.css",
  "js": "script.ts",
  "assets": {
    "a": {
      "type": "font",
      "builtin": "Inter"
    },
    "b": {
      "type": "font",
      "file": "faith.otf"
    }
  },
  "settings": {
    "audio": {
      "type": "audio",
      "name": "Audio",
      "default": ""
    },
    "boolean": {
      "type": "boolean",
      "name": "Boolean",
      "description": "here's a bit of a long description for testing",
      "default": false
    },
    "color": {
      "type": "color",
      "name": "Color",
      "group": "Color:",
      "default": "#FF00FF"
    },
    "color_array": {
      "type": "color_array",
      "name": "ColorArray",
      "group": "Color:",
      "default": [
        "#FF0000",
        "#00FF00",
        "#0000FF"
      ]
    },
    "color_choices": {
      "type": "color",
      "name": "ColorChoices",
      "group": "Color:",
      "default": "#FF0000",
      "choices": {
        "#FF0000": "Red",
        "#00FF00": "Green",
        "#0000FF": "Blue"
      }
    },
    "decimal": {
      "type": "decimal",
      "name": "Decimal",
      "default": 1.1
    },
    "decimal_array": {
      "type": "decimal_array",
      "name": "DecimalArray",
      "default": [
        2.2,
        3.3,
        4.4
      ]
    },
    "decimal_choices": {
      "type": "decimal",
      "name": "DecimalChoices",
      "default": 3.3,
      "choices": {
        "2.2": "Two",
        "3.3": "Three",
        "4.4": "Four"
      }
    },
    "font": {
      "type": "font",
      "name": "Font",
      "default": "Faith",
      "custom": {
        "faith.otf": "Faith"
      }
    },
    "image": {
      "type": "image",
      "name": "Image"
    },
    "integer": {
      "type": "integer",
      "name": "Integer",
      "group": "Integer:",
      "default": 1
    },
    "integer_array": {
      "type": "integer_array",
      "name": "IntegerArray",
      "group": "Integer:",
      "default": [
        2,
        3,
        4
      ]
    },
    "integer_choices": {
      "type": "integer",
      "name": "IntegerChoices",
      "group": "Integer:",
      "default": 3,
      "choices": {
        "2": "Two",
        "3": "Three",
        "4": "Four"
      }
    },
    "string": {
      "type": "string",
      "name": "String",
      "default": "abc"
    },
    "string_array": {
      "type": "string_array",
      "name": "StringArray",
      "default": [
        "abc",
        "def",
        "xyz"
      ]
    },
    "string_choices": {
      "type": "string",
      "name": "StringChoices",
      "default": "abc",
      "choices": {
        "abc": "Abc",
        "def": "Def",
        "xyz": "Xyz"
      }
    },
    "timezone": {
      "type": "timezone",
      "name": "Timezone",
      "default": "America/New_York"
    },
    "video": {
      "type": "video",
      "name": "Video"
    }
  }
}